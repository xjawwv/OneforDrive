    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer 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"
      }
    },
    "git": {
      "type": "local",
      "command": ["uvx", "mcp-server-git", "--repository", "D:/Github/OneforDrive"],
      "enabled": true
    },
    "browsermcp": {
      "type": "local",
      "command": ["npx", "-y", "@browsermcp/mcp@latest"],
      "enabled": true
    }
  }
